# ─── Brevo (Email Service Provider) ───────────────────────────────────────────
# Required. Get from Brevo dashboard → Settings → API Keys
BREVO_API_KEY=your_brevo_api_key_here

# ─── hCaptcha (optional bot protection) ───────────────────────────────────────
# Leave empty to disable captcha on subscription/calculator forms.
# Get from https://dashboard.hcaptcha.com
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=
